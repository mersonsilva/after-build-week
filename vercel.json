{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/seguranca-infantil",
      "destination": "/seguranca-infantil.html"
    },
    {
      "source": "/child-safety-standards",
      "destination": "/seguranca-infantil.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
